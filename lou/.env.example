OPENAI_API_KEY=                    # Fill this in before running the LLM-backed features.
LLM_MODEL=gpt-5.5
LLM_FALLBACK_MODELS=gpt-5.5
LLM_TEMPERATURE=0.1
EMBEDDING_MODEL=all-mpnet-base-v2
LOU_EMBEDDING_MODEL_PATH=./models/lou-retriever
LOU_CLASSIFIER_PATH=./models/clause-classifier/model.joblib
LOU_CLASSIFIER_CONFIDENCE_THRESHOLD=0.70
TRAINING_DATA_DIR=./data/training
CHROMA_PERSIST_DIR=./data/chroma
UPLOAD_DIR=./data/uploads
DATABASE_URL=sqlite:///./data/lou.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175
MAX_UPLOAD_SIZE_MB=50
